# .env.example
# REIT Lens - Institutional Analytics

# Gemini API Key -- NO LONGER STORED HERE
# The Gemini API key is now a server-side secret on the Supabase Edge Function.
# Set it via: supabase secrets set GEMINI_API_KEY=your-key-here
# See SECURITY.md for details.

# SEC EDGAR API (Optional, for live data sync)
# SEC_API_KEY=

# Supabase Authentication & Database
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# FRED API Key (Free, register at https://fred.stlouisfed.org/docs/api/api_key.html)
# Used for: 10Y Treasury (DGS10), HY Spread (BAMLH0A0HYM2), Fed Funds (FEDFUNDS), CPI (CPIAUCSL)
# If not configured, Macro page falls back to synthetic data with a warning.
VITE_FRED_API_KEY=
